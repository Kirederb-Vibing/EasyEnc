DJANGO_SECRET_KEY=skift-denne-til-noget-tilfaeldigt

# User/group ID — file permissions inherit from this user
# 0:0 = root, 1000:1000 = typical first user
PUID=1000
PGID=1000

# Directories the service can access (comma-separated)
# These must also be mounted as volumes in docker-compose.yml
ALLOWED_DIRS=/mnt/media,/mnt/output

# Mount paths (map host dirs into the container)
# Add as many as you need — match with ALLOWED_DIRS
MEDIA_PATH_1=/mnt/media
MEDIA_PATH_2=/mnt/output
MEDIA_PATH_3=
